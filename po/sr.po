#: data/app.drey.EarTag.desktop.in:12
msgid "music;audio;tag;tagging;tagger;"
msgstr "music;audio;tag;tagging;tagger;музика;аудио;звук;таг;ознака;таговање;"

#: data/app.drey.EarTag.metainfo.xml.in:112
msgid "Ear Tag is a simple audio file tag editor. It is primarily geared towards making quick edits or bulk-editing tracks in albums/EPs. Unlike other tagging programs, Ear Tag does not require the user to set up a music library folder. It can:"
msgstr "Ушна ознака је једноставан уређивач ознака звучних датотека. Првенствено је намењена за брзе измене или групно уређивање песама у албумима/ЕП-овима. За разлику од других програма за означавање, Ушна ознака не захтева од корисника да подеси фасциклу музичке збирке. Она може:"

#: data/app.drey.EarTag.metainfo.xml.in:114
msgid "Edit tags of MP3, WAV, M4A, FLAC, OGG and WMA files"
msgstr "да уређује ознаке MP3, WAV, M4A, FLAC, OGG и WMA датотека"

#: data/app.drey.EarTag.metainfo.xml.in:115
msgid "Modify metadata of multiple files at once"
msgstr "да мења метаподатке више датотека одједном"

#: data/app.drey.EarTag.metainfo.xml.in:116
msgid "Rename files using information from present tags"
msgstr "да преименује датотеке користећи податке из постојећих ознака"

#: data/app.drey.EarTag.metainfo.xml.in:117
msgid "Identify files using AcoustID"
msgstr "да идентификује датотеке користећи AcoustID"

#: data/app.drey.EarTag.metainfo.xml.in:119
msgid "Network access is only used for the \"Identify selected files\" option."
msgstr "Приступ мрежи се користи само за опцију „Идентификуј изабране датотеке“."

